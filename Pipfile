[[source]]
name = "pypi"
url = "https://pypi.org/simple"
verify_ssl = true

[packages]
fastapi = ">=0.115.0,<0.116"
uvicorn = {extras = ["standard"], version = ">=0.32.0,<0.33"}
pydantic = ">=2.10.0,<3"
httpx = ">=0.27.0,<0.29"
python-multipart = ">=0.0.9,<0.1"
numpy = ">=2.0.0,<3"

[dev-packages]
pytest = ">=8.0.0,<9"
pytest-cov = ">=5.0.0,<7"
flake8 = ">=7.0.0,<8"

[requires]
python_version = "3.12"

[scripts]
tests = "pytest -q src_starting_point/tests tests"
